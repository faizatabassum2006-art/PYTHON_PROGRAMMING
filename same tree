class Solution:
    def isSameTree(self, p: Optional[TreeNode], q: Optional[TreeNode]) -> bool:
        if not p and not q:
            return True
        if not p or not q:
            return False
        if p.val!=q.val:
            return False
        lt=self.isSameTree(p.left,q.left)
        rt=self.isSameTree(p.right,q.right)
        if lt and rt:
            return True
        else:
            return False

        
