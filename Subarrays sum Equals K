class Solution:
    def subarraySum(self, nums: List[int], k: int) -> int:
        prefix_sum=0
        dic={0:1}
        res=0
        for n in nums:
            prefix_sum+=n
            if prefix_sum-k in dic:
                res+=dic[prefix_sum-k]
            dic[prefix_sum]=dic.get(prefix_sum,0)+1
        return res
        
